# PhysioAI backend (Prisma + PostgreSQL on Railway). Copy to .env and fill in.

# Railway Postgres connection string.
#   • Deployed ON Railway (same project): use the INTERNAL url
#       postgresql://postgres:PASS@postgres.railway.internal:5432/railway
#   • Local dev / running `prisma db push` from your machine: use the PUBLIC url
#       (Railway → Postgres service → Variables → DATABASE_PUBLIC_URL)
#       postgresql://postgres:PASS@<name>.proxy.rlwy.net:<PORT>/railway
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Secret for signing JWTs (generate a long random string).
JWT_SECRET=change-me-to-a-long-random-string

# Optional
# JWT_EXPIRES=30d
# PORT=3000
